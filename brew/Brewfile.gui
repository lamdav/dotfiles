# Window Management & Status Bar
brew "FelixKratz/formulae/borders"  # window borders for AeroSpace
cask "nikitabobko/tap/aerospace"
cask "ubersicht"

# Fonts
cask "font-fira-code"
cask "font-fira-code-nerd-font"

#!/usr/bin/env bash
# Generate changelog and tag a release using git-cliff.
# Usage: release          # auto-bump based on conventional commits
#        release patch    # force patch bump
#        release minor    # force minor bump
#        release major    # force major bump
set -euo pipefail

BUMP_FLAG="--bump"
case "${1:-}" in
    patch) BUMP_FLAG="--bump-patch" ;;
    minor) BUMP_FLAG="--bump-minor" ;;
    major) BUMP_FLAG="--bump-major" ;;
    "")    BUMP_FLAG="--bump" ;;
    *)
        echo "Usage: release [patch|minor|major]" >&2
        exit 1
        ;;
esac

# Determine the next version for the commit message
if git tag --list | grep -q .; then
    NEW_VERSION=$(git cliff "$BUMP_FLAG" --bumped-version)
else
    NEW_VERSION="v1.0.0"
fi

echo "Releasing $NEW_VERSION..."

git cliff "$BUMP_FLAG" --tag "$NEW_VERSION" -o CHANGELOG.md
git add CHANGELOG.md
git commit -m "chore: release $NEW_VERSION"
git tag -a "$NEW_VERSION" -m "Release $NEW_VERSION"

echo "✓ Tagged $NEW_VERSION"
